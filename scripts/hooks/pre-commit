#!/bin/bash
# Auto patch-bump when workflow files change (unless VERSION already staged).

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$ROOT/VERSION"

STAGED="$(git diff --cached --name-only)"

version_staged=false
echo "$STAGED" | grep -qx 'VERSION' && version_staged=true

needs_bump=false
while IFS= read -r path; do
  [ -n "$path" ] || continue
  case "$path" in
    skills/*/SKILL.md|commands/*.md|references/*.md)
      needs_bump=true
      break
      ;;
  esac
done <<< "$STAGED"

if [ "$needs_bump" = true ] && [ "$version_staged" = false ]; then
  echo "pre-commit: workflow files changed — bumping patch version"
  "$ROOT/scripts/bump-version.sh" patch
  git add VERSION .claude-plugin/plugin.json .claude-plugin/marketplace.json README.md
fi

"$ROOT/scripts/sync-version.sh" --check
