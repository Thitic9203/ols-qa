#!/bin/bash
# ols-qa pre-commit — EARLIEST guard: block committing an OLS secret into a SHARED
# skill file (one that also exists in the helix plugin), before it can ever be synced —
# and before it lands in this PUBLIC ols-qa repo. Non-shared OLS files (e.g.
# references/ols-project-guide.md) are EXEMPT — this workspace legitimately holds OLS
# config; only the generic/shared files must stay clean.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
HELIX="${HELIX_REPO:-$HOME/GitHub/helix}"
GUARD="$HELIX/scripts/check-no-secrets.sh"

# Which staged files are SHARED (present in helix)?
STAGED="$(git diff --cached --name-only --diff-filter=ACM)"
SHARED=()
while IFS= read -r f; do
  [ -n "$f" ] || continue
  case "$f" in skills/*|references/*|commands/*) ;; *) continue ;; esac
  [ -f "$HELIX/$f" ] || continue          # "shared" = present in helix
  SHARED+=("$f")
done <<< "$STAGED"

[ "${#SHARED[@]}" -gt 0 ] || exit 0        # nothing shared staged → nothing to guard

# Shared file staged but guard unavailable → FAIL CLOSED (never commit a shared file
# unguarded into a public repo).
if [ ! -x "$GUARD" ]; then
  echo "[ols-qa pre-commit] ❌ secret guard not found at $GUARD but SHARED skill file(s) are staged."
  echo "  Restore the helix guard (or unstage the shared files). Commit BLOCKED (fail-closed)."
  exit 1
fi

# Scan the STAGED blobs (not the dirty working tree) via a mirrored temp tree.
echo "[ols-qa pre-commit] scanning ${#SHARED[@]} staged shared skill file(s) for OLS secrets…"
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT
for f in "${SHARED[@]}"; do
  mkdir -p "$TMP/$(dirname "$f")"
  git show ":$f" > "$TMP/$f" 2>/dev/null || continue
done

if ! SCAN_ROOT="$TMP" "$GUARD" "${SHARED[@]}"; then
  echo "[ols-qa pre-commit] ❌ OLS secret in a SHARED skill file — commit BLOCKED."
  echo "  Move OLS config (URLs/accounts/IDs) into references/ols-project-guide.md (ols-qa-only, never synced),"
  echo "  and use placeholders {ISSUE_KEY}/{JIRA_DOMAIN}/{PORTAL} in shared skills."
  exit 1
fi
exit 0
