#!/bin/bash
# ols-qa pre-commit — THIS REPO IS PUBLIC.
#
# Guards EVERY staged text file, not just the ones shared with helix. The old version
# exempted non-shared paths (references/ols-project-guide.md etc.) on the assumption that
# this workspace was a private vault for OLS config. That assumption died when the repo
# was made public on 2026-06-11 — the exemption is what let credentials, internal hosts and
# resource ids reach GitHub. Real values now live in ~/.ols-qa-secrets/ols-secrets.md,
# outside the repo, and repo docs carry placeholders only.
#
# Fails CLOSED: a missing or erroring scanner blocks the commit.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
GUARD="$ROOT/scripts/check-no-secrets.sh"

# Staged text files (skip binaries — screenshots are scanned by eye, not by regex).
STAGED=()
while IFS= read -r f; do
  [ -n "$f" ] || continue
  case "$f" in
    *.png|*.jpg|*.jpeg|*.gif|*.webm|*.mp4|*.pdf|*.zip|*.csv) continue ;;
  esac
  STAGED+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM)

[ "${#STAGED[@]}" -gt 0 ] || exit 0

if [ ! -x "$GUARD" ]; then
  echo "[ols-qa pre-commit] ❌ secret guard missing or not executable: $GUARD"
  echo "  Restore it (chmod +x). Commit BLOCKED (fail-closed) — this repo is public."
  exit 1
fi

echo "[ols-qa pre-commit] scanning ${#STAGED[@]} staged file(s) for OLS secrets…"

# Scan the STAGED blobs, not the dirty working tree.
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT
for f in "${STAGED[@]}"; do
  mkdir -p "$TMP/$(dirname "$f")"
  git show ":$f" > "$TMP/$f" 2>/dev/null || continue
done

SCAN_ROOT="$TMP" "$GUARD" "${STAGED[@]}"
rc=$?
if [ "$rc" -ne 0 ]; then
  echo "[ols-qa pre-commit] ❌ commit BLOCKED (guard exit $rc)."
  echo "  Use the placeholder instead of the real value. Mapping:"
  echo "    ~/.ols-qa-secrets/ols-secrets.md"
  exit 1
fi
exit 0
