{
  "//": "OLS QA workspace settings. Auto-applied when you open this repo in Claude Code and trust the folder.",
  "permissions": {
    "allow": [
      "Bash(git pull *)",
      "Bash(git rev-parse *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(which *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(npx playwright *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-context.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact.sh\""
          }
        ]
      }
    ]
  }
}
