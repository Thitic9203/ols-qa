#!/usr/bin/env bash
# SessionStart hook for Helix plugin — injects QA routing discipline (not a full skill dump).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Best-effort update to latest GitHub release (skills + helix@helix); see scripts/helix-auto-update.sh
if [ -x "${PLUGIN_ROOT}/scripts/helix-auto-update.sh" ]; then
  HELIX_QUIET=1 HELIX_REPO_DIR="${HELIX_REPO_DIR:-$HOME/.helix/tc-fe-prep}" \
    bash "${PLUGIN_ROOT}/scripts/helix-auto-update.sh" 2>/dev/null || true
elif [ -x "$HOME/.helix/tc-fe-prep/scripts/helix-auto-update.sh" ]; then
  HELIX_QUIET=1 bash "$HOME/.helix/tc-fe-prep/scripts/helix-auto-update.sh" 2>/dev/null || true
fi

# One-time, consent-gated notice about the opt-in "fewer prompts" devenv config.
# We do NOT silently change anyone's global ~/.claude settings — we only surface the
# command so the user can choose. Shown at most 3 times, never once opted in.
# Silence with HELIX_DEVENV_NOTICE=0.
devenv_tip=""
_optin="$HOME/.helix/.devenv-opted-in"
_ncfile="$HOME/.helix/.devenv-notice-count"
if [ "${HELIX_DEVENV_NOTICE:-1}" != "0" ] && [ ! -f "$_optin" ]; then
  _n=0
  [ -f "$_ncfile" ] && _n=$(tr -dc '0-9' <"$_ncfile" 2>/dev/null || echo 0)
  _n=${_n:-0}
  if [ "$_n" -lt 3 ]; then
    devenv_tip="\n\n---\n**Helix tip (optional, dev-only):** If you write code with this agent, you can cut confirmation prompts. Tell the user ONCE, briefly: they may run \`bash ~/.helix/tc-fe-prep/scripts/helix-setup-devenv.sh\` (opt-in, backs up first, reversible via \`--uninstall\`) to enable acceptEdits + a safe command allowlist globally. Pure-QA users can ignore. Silence: HELIX_DEVENV_NOTICE=0."
    mkdir -p "$HOME/.helix" 2>/dev/null || true
    echo $((_n + 1)) >"$_ncfile" 2>/dev/null || true
  fi
fi

# Proactive QA hint (suggest-only; opt-out HELIX_PROACTIVE=0). Woven into the context
# JSON below — NEVER echoed separately (would corrupt the single JSON object).
# Rules: references/proactive-qa-triggers.md. Never auto-runs a workflow (Rule #5).
proactive_tip=""
if [ "${HELIX_PROACTIVE:-1}" != "0" ] && command -v git >/dev/null 2>&1; then
  _pqa_dir="${CLAUDE_PROJECT_DIR:-$PWD}"
  _pqa_branch="$(git -C "$_pqa_dir" branch --show-current 2>/dev/null || true)"
  case "$_pqa_branch" in
    feat/*|feature/*) proactive_tip="\n\n---\n**Helix proactive hint (suggest-only):** Branch \`${_pqa_branch}\` may suit **TC FE prep** (\`/tc-fe-prep\`), or TC API prep if API-only. Suggestion only — nothing runs until the user picks from /helix. Silence: HELIX_PROACTIVE=0." ;;
    fix/*|bugfix/*|hotfix/*) proactive_tip="\n\n---\n**Helix proactive hint (suggest-only):** Branch \`${_pqa_branch}\` may suit **Retest bug** (\`/retest-bug\`). Suggestion only — nothing runs until the user picks from /helix. Silence: HELIX_PROACTIVE=0." ;;
  esac
fi

session_context="<EXTREMELY_IMPORTANT>\n**Helix** QA workflows available via slash-commands below. Each command loads its workflow — not ad-hoc procedure.\n\n| Command | Workflow |\n|---------|----------|\n| \`/helix\` | Router menu |\n| \`/tc-fe-prep\` | FE test case prep |\n| \`/tc-api-prep\` | API test case prep |\n| \`/retest-bug\` | Retest a bug fix |\n| \`/testing-ticket\` | Playwright ticket test |\n| \`/create-bug\` | File a new bug |\n\nEvidence before claims: no done/passed without proof. English for user chat.\n</EXTREMELY_IMPORTANT>${devenv_tip}${proactive_tip}"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
